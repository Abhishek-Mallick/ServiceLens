# ─────────────────────────────────────────────────────────────────────────────
# Required: Database
# ─────────────────────────────────────────────────────────────────────────────
# Grab both URLs from the Neon console (Dashboard → Connection Details).
# DATABASE_URL = pooled connection (uses PgBouncer) — what the app runs against.
# DIRECT_URL   = direct connection — used by `prisma db push` / migrate / seed.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/servicelens?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/servicelens?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# Required: NextAuth
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"

# ─────────────────────────────────────────────────────────────────────────────
# Optional: GitHub OAuth (credentials auth works without these)
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# Optional: AI (OpenRouter free tier; app falls back to heuristic analyzer)
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Notifications (Phase 2)
#   - RESEND_API_KEY enables email notifications (https://resend.com)
#   - RESEND_FROM is the verified sender, e.g. "ServiceLens <alerts@yourdomain>"
#   - SLACK_WEBHOOK_URL is a default fallback channel; per-architecture
#     channels are configured in the app UI.
# Without these keys the platform logs notifications to console.
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM="ServiceLens <alerts@example.com>"
SLACK_WEBHOOK_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# Optional: GitHub App for AI fix-PR creation (Phase 4)
# Without these the fix-PR feature renders the diff in the UI only
# ("Copy as patch") and never opens a real PR.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_INSTALLATION_ID=""

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Redis (Phase 7 — swaps in BullMQ for the Job queue)
# The in-process worker in lib/jobs.ts is used until this is set.
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo credentials (seeded user)
#   email: demo@servicelens.com
#   password: demo123
