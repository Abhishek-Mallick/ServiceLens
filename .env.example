# Neon Postgres
# Grab both URLs from the Neon console (Dashboard → Connection Details).
# DATABASE_URL = pooled connection (uses PgBouncer) — what the app runs against.
# DIRECT_URL   = direct connection — used by `prisma db push` / migrate / seed.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/servicelens?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/servicelens?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"

# GitHub OAuth (optional — credentials auth works without these)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OpenRouter (free tier; app gracefully degrades if unset)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# Redis (for BullMQ; optional — app falls back to in-process queue)
REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo credentials (seeded user)
# email: demo@servicelens.com
# password: demo123
