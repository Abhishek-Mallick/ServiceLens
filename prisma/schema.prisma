// ServiceLens Prisma schema.
// Neon Postgres. DATABASE_URL = pooled (pgbouncer) connection for the app runtime;
// DIRECT_URL = direct (unpooled) connection used by prisma migrate / db push / seed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String?
  image         String?
  githubId      String?        @unique
  architectures Architecture[]
  assignedIncidents Incident[] @relation("incidentAssignee")
  incidentEvents IncidentEvent[]
  notifications Notification[]
  notificationPref UserNotificationPref?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Architecture {
  id             String          @id @default(cuid())
  name           String
  description    String?
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  services       Service[]
  regressionRuns RegressionRun[]
  alertRules     AlertRule[]
  incidents      Incident[]
  chaosSchedules ChaosSchedule[]
  status         String          @default("draft") // draft, analyzing, ready, error
  topologyData   String? // JSON; cached topology graph data
  slackWebhookUrl String? // Phase 2: per-architecture Slack incoming webhook
  notificationsEmail String? // optional override; defaults to architecture owner email
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Service {
  id              String               @id @default(cuid())
  name            String
  repoUrl         String
  branch          String               @default("main")
  architectureId  String
  architecture    Architecture         @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  analysisStatus  String               @default("pending") // pending, cloning, analyzing, completed, error
  analysisResult  String? // JSON: full AI analysis result
  language        String?
  framework       String?
  summary         String?
  producesEvents  String? // JSON array
  consumesEvents  String? // JSON array
  exposesApis     String? // JSON array
  consumesApis    String? // JSON array
  databases       String? // JSON array
  kafkaTopics     String? // JSON array
  healthEndpoint  String?
  healthStatus    String               @default("unknown") // healthy, degraded, down, unknown
  lastHealthCheck DateTime?
  simulated       Boolean              @default(false) // true when health/data is generated, not from real probes
  ingestToken     String?              @unique // bearer for HEC-style log ingestion (POST /api/services/:id/logs)
  dependencies    ServiceDependency[]  @relation("dependentService")
  dependents      ServiceDependency[]  @relation("dependencyService")
  healthHistory   HealthRecord[]
  testSteps       RegressionTestStep[]
  probes          Probe[]
  alertRules      AlertRule[]
  incidents       Incident[]
  logs            LogEntry[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model ServiceDependency {
  id           String   @id @default(cuid())
  dependentId  String
  dependent    Service  @relation("dependentService", fields: [dependentId], references: [id], onDelete: Cascade)
  dependencyId String
  dependency   Service  @relation("dependencyService", fields: [dependencyId], references: [id], onDelete: Cascade)
  type         String // kafka | rest | grpc | database | event
  details      String? // JSON: topic, endpoint, etc
  createdAt    DateTime @default(now())

  @@unique([dependentId, dependencyId, type])
}

model HealthRecord {
  id           String   @id @default(cuid())
  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status       String // healthy | degraded | down
  responseTime Int?
  details      String? // JSON
  simulated    Boolean  @default(false)
  checkedAt    DateTime @default(now())

  @@index([serviceId, checkedAt])
}

model RegressionRun {
  id             String               @id @default(cuid())
  architectureId String
  architecture   Architecture         @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  status         String               @default("pending") // pending | running | completed | failed
  triggeredBy    String?
  startedAt      DateTime?
  completedAt    DateTime?
  totalSteps     Int                  @default(0)
  passedSteps    Int                  @default(0)
  failedSteps    Int                  @default(0)
  steps          RegressionTestStep[]
  summary        String? // JSON: AI summary
  simulated      Boolean              @default(false)
  createdAt      DateTime             @default(now())
}

// Job — generic async work queue. v1 is in-process; later phases swap in Inngest/BullMQ
// without changing this row contract.
model Job {
  id          String    @id @default(cuid())
  type        String // probe, analyze, regression, rca, fix_pr, notify, chaos
  payload     String // JSON
  status      String    @default("pending") // pending | running | completed | failed | cancelled
  result      String? // JSON
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([type, status])
}

model RegressionTestStep {
  id             String        @id @default(cuid())
  runId          String
  run            RegressionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  stepOrder      Int
  name           String
  description    String?
  type           String // api_call | event_produce | event_consume | db_write | db_read | health_check
  status         String        @default("pending") // pending | running | passed | failed | skipped
  input          String? // JSON
  expectedOutput String? // JSON
  actualOutput   String? // JSON
  errorMessage   String?
  duration       Int?
  executedAt     DateTime?

  @@index([runId, stepOrder])
}

// Probe — declarative health probe configuration. One service can carry many.
model Probe {
  id             String    @id @default(cuid())
  serviceId      String
  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name           String
  type           String // http | tcp | ping | cmd
  target         String // URL for http; host:port for tcp/ping; shell for cmd
  intervalSec    Int       @default(30)
  timeoutSec     Int       @default(5)
  expectStatus   Int? // for http; default 2xx ok
  expectBodyRegex String?
  headers        String? // JSON
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([serviceId, enabled])
}

// AlertRule — when to open an incident. Conditions are JSON DSL.
model AlertRule {
  id             String       @id @default(cuid())
  architectureId String
  architecture   Architecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  // JSON: { kind: 'status_eq'|'p95_latency_gt'|'error_rate_gt'|'consecutive_down'|'regression_failed', ...params }
  condition      String
  windowSec      Int          @default(300)
  forDurationSec Int          @default(60)
  severity       String       @default("warning") // info | warning | critical
  channels       String       @default("[\"inapp\"]") // JSON string[]: inapp|email|slack|webhook
  enabled        Boolean      @default(true)
  incidents      Incident[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([architectureId, enabled])
}

// Incident — fires open when a rule matches for >= forDurationSec; auto-resolves
// when the underlying condition has cleared for 2x the window.
model Incident {
  id             String          @id @default(cuid())
  architectureId String
  architecture   Architecture    @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  ruleId         String?
  rule           AlertRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  serviceId      String?
  service        Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  title          String
  severity       String          @default("warning") // info | warning | critical
  status         String          @default("open") // open | acknowledged | mitigated | resolved
  source         String          @default("rule") // rule | synthetic | manual
  summary        String?
  rcaMarkdown    String?
  rcaModel       String?
  resolution     String?
  assigneeId     String?
  assignee       User?           @relation("incidentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  openedAt       DateTime        @default(now())
  ackedAt        DateTime?
  resolvedAt     DateTime?
  simulated      Boolean         @default(false)
  events         IncidentEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([architectureId, status, openedAt])
  @@index([ruleId, serviceId, status])
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       String // opened | acked | resolved | status_change | comment | rca_started | rca_completed | fix_pr_generated | notification_sent | assigned
  payload    String? // JSON
  byUserId   String?
  byUser     User?    @relation(fields: [byUserId], references: [id], onDelete: SetNull)
  at         DateTime @default(now())

  @@index([incidentId, at])
}

// In-app notification feed (bell icon).
model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       String // incident_opened | incident_acked | incident_resolved | fix_pr_ready
  title      String
  body       String?
  href       String? // deep link into the app
  severity   String?  @default("info")
  incidentId String? // optional foreign reference (not enforced for simplicity)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, readAt, createdAt])
}

// Delivery audit log — one row per dispatched notification per channel.
model NotificationLog {
  id         String   @id @default(cuid())
  incidentId String?
  channel    String // inapp | email | slack | webhook | console
  status     String // sent | failed | skipped
  recipient  String? // email address, slack channel, etc
  template   String? // IncidentOpened, IncidentResolved, ...
  payload    String? // JSON snapshot of what was sent
  error      String?
  at         DateTime @default(now())

  @@index([incidentId, at])
  @@index([channel, status])
}

// ChaosSchedule — recurring fault injection on a target service. v1 supports
// a tiny schedule grammar (kept simple on purpose; Vercel-Cron compatible
// 5-field crons are a Phase 7 follow-up): "every 5m", "every 1h", or "HH:MM"
// (UTC daily). Per-row lastRunAt acts as the dedup gate.
model ChaosSchedule {
  id             String       @id @default(cuid())
  architectureId String
  architecture   Architecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  targetServiceId String
  schedule       String // "every 5m" | "every 1h" | "HH:MM"
  action         String // kill_service | degrade | latency_spike
  durationSec    Int          @default(300)
  enabled        Boolean      @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([architectureId, enabled])
}

model LogEntry {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  level     String // debug | info | warn | error
  message   String
  fields    String? // JSON map of extra structured fields
  traceId   String?
  spanId    String?
  simulated Boolean  @default(false)
  at        DateTime @default(now())

  @@index([serviceId, at])
  @@index([serviceId, level, at])
  @@index([traceId])
}

model UserNotificationPref {
  userId          String  @id
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled    Boolean @default(true)
  slackEnabled    Boolean @default(true)
  minSeverity     String  @default("warning") // info | warning | critical — below this is suppressed for email/slack
  quietHoursStart Int? // 0..23, local-time hour; null = always on
  quietHoursEnd   Int? // 0..23
  updatedAt       DateTime @updatedAt
}
